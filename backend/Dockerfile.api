FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY pyproject.toml .
RUN pip install --no-cache-dir .

COPY . .

# Expose port
EXPOSE 8000

# Start FastAPI
CMD ["uvicorn", "services.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
