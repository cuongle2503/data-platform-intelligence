{
  "title": "IDP Containers — cAdvisor",
  "uid": "idp-cadvisor",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {"title": "CPU per Container", "type": "timeseries", "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}, "targets": [{"expr": "rate(container_cpu_usage_seconds_total{name=~\".+\"}[2m])", "legendFormat": "{{name}}"}]},
    {"title": "Memory per Container", "type": "timeseries", "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "bytes"}}, "targets": [{"expr": "container_memory_usage_bytes{name=~\".+\"}", "legendFormat": "{{name}}"}]},
    {"title": "Network RX", "type": "timeseries", "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "Bps"}}, "targets": [{"expr": "rate(container_network_receive_bytes_total{name=~\".+\"}[2m])", "legendFormat": "{{name}}"}]},
    {"title": "Network TX", "type": "timeseries", "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "Bps"}}, "targets": [{"expr": "rate(container_network_transmit_bytes_total{name=~\".+\"}[2m])", "legendFormat": "{{name}}"}]},
    {"title": "Filesystem Usage", "type": "bargauge", "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "bytes"}}, "targets": [{"expr": "container_fs_usage_bytes{name=~\".+\"}", "legendFormat": "{{name}}"}]},
    {"title": "Disk I/O", "type": "timeseries", "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "Bps"}}, "targets": [{"expr": "rate(container_fs_reads_bytes_total{name=~\".+\"}[2m])", "legendFormat": "{{name}} read"}, {"expr": "rate(container_fs_writes_bytes_total{name=~\".+\"}[2m])", "legendFormat": "{{name}} write"}]}
  ]
}
