{
  "title": "Elasticsearch Overview",
  "uid": "elasticsearch-overview",
  "schemaVersion": 39,
  "refresh": "10s",
  "panels": [
    {"title": "Cluster Health", "type": "stat", "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}, "targets": [{"expr": "elasticsearch_cluster_health_status", "legendFormat": "{{status}}"}]},
    {"title": "Nodes Count", "type": "stat", "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}, "targets": [{"expr": "elasticsearch_cluster_health_number_of_nodes"}]},
    {"title": "Indices Count", "type": "stat", "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}, "targets": [{"expr": "elasticsearch_cluster_health_number_of_indices"}]},
    {"title": "JVM Heap Usage", "type": "timeseries", "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}, "fieldConfig": {"defaults": {"unit": "percent"}}, "targets": [{"expr": "elasticsearch_jvm_memory_used_bytes{area=\"heap\"} / elasticsearch_jvm_memory_max_bytes{area=\"heap\"} * 100", "legendFormat": "{{node}}"}]},
    {"title": "Search Query Rate", "type": "timeseries", "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}, "targets": [{"expr": "rate(elasticsearch_indices_search_query_total[2m])", "legendFormat": "{{index}}"}]}
  ]
}
