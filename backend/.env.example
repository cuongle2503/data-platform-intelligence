# =============================================================================
# IDP Environment Configuration Template
# Copy to .env and fill in secrets before running Docker Compose
# =============================================================================

# --- General ---
TZ=Asia/Ho_Chi_Minh
COMPOSE_PROJECT_NAME=idp

# --- MinIO (Phase 1) ---
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=http://minio:9000
MINIO_CONNECTOR_ENDPOINT=http://127.0.0.1:9000

# --- PostgreSQL (Phase 3) ---
POSTGRES_USER=idp_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=idp_warehouse
POSTGRES_PORT=5433

# --- Airflow (Phase 4) ---
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://idp_admin:CHANGE_ME@postgres:5432/airflow_db
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_generate_with_python_cryptography_fernet
AIRFLOW_WEBSERVER_SECRET_KEY=CHANGE_ME

# --- DuckDB S3 access (Phase 3) ---
DUCKDB_S3_ENDPOINT=minio:9000
DUCKDB_S3_ACCESS_KEY=minio_admin
DUCKDB_S3_SECRET_KEY=CHANGE_ME
DUCKDB_S3_USE_SSL=false
DUCKDB_S3_URL_STYLE=path

# --- Host-side connectors (override for host dev) ---
# DUCKDB_S3_ENDPOINT=127.0.0.1:9000

# --- Optional: External API keys ---
# GEMINI_API_KEY=
# FRED_API_KEY=
# NSO_API_KEY=
